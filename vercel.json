{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/repos.json", "dest": "/repos.json" },
    { "src": "/project_details.html", "dest": "/project_details.html" },
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}